<section>
  <h1>Назначение курьеров</h1>
  <form method="get" class="filters">
    <input type="text" name="search" value="{{search}}" placeholder="Поиск (ID, клиент, email, телефон)" />
    <button class="btn" type="submit">Найти</button>
  </form>

  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Клиент</th>
        <th>Телефон</th>
        <th>Адрес</th>
        <th>Слот</th>
        <th>Статус</th>
        <th>Курьер</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
        <tr>
          <td>{{id}}</td>
          <td>{{user_name}}<br /><small>{{user_email}}</small></td>
          <td>{{phone}}</td>
          <td>{{city}}, {{street}}, {{house}}</td>
          <td>{{slot_label}}</td>
          <td>{{status}}</td>
          <td>{{#if courier_name}}{{courier_name}}{{else}}Не назначен{{/if}}</td>
          <td>
            <form method="post" action="/admin/dispatch/{{id}}" class="inline-form assign-form">
              <select name="courier_id">
                <option value="" {{#unless courier_id}}selected{{/unless}}>Не назначен</option>
                {{#each ../couriers}}
                  <option value="{{id}}" {{#if (eq id ../courier_id)}}selected{{/if}}>{{full_name}}</option>
                {{/each}}
              </select>
              <button class="btn" type="submit">Сохранить</button>
            </form>
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</section>
