<section>
  <h1>Оформление заказа</h1>

  {{#if cartItems.length}}
    {{#if errors}}
      <ul class="errors">
        {{#each errors}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
    {{/if}}

    <form method="post" class="form card">
      <label>Телефон (Россия)
        <input type="tel" name="phone" value="{{form.phone}}" placeholder="+7 999 123-45-67" pattern="^(\\+7|8)\\s?\\(?\\d{3}\\)?[\\s-]?\\d{3}[\\s-]?\\d{2}[\\s-]?\\d{2}$" title="Формат: +7 999 123-45-67" required />
      </label>

      <h3>Адрес доставки</h3>
      <p class="category">Доставка работает только по городу Казань.</p>
      <label>Город
        <input type="text" value="Казань" readonly />
      </label>
      <label>Улица
        <input type="text" name="street" value="{{form.street}}" required />
      </label>
      <label>Дом
        <input type="text" name="house" value="{{form.house}}" required />
      </label>
      <label>Квартира
        <input type="text" name="apartment" value="{{form.apartment}}" />
      </label>
      <label>Комментарий к адресу
        <input type="text" name="comment_text" value="{{form.comment_text}}" />
      </label>

      <label>Удобное время доставки
        <select name="slot_id" required>
          {{#each slots}}
            <option value="{{id}}" {{#if (eq id ../form.slot_id)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>

      <div class="cart-summary">
        <p>Сумма без скидки: {{formatCurrency subtotal}}</p>
        <p>Текущая скидка: {{formatCurrency discountTotal}}</p>
        <p><strong>К оплате при доставке: {{formatCurrency total}}</strong></p>
      </div>

      <button class="btn" type="submit">Подтвердить заказ</button>
    </form>
  {{else}}
    <p>Корзина пуста. Невозможно оформить заказ.</p>
    <a class="btn" href="/catalog">В каталог</a>
  {{/if}}
</section>
